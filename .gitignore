node_modules

# Playwright e2e artifacts (regenerated on every run)
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
dist
dist-ssr
*.local

# Vite mode-scoped env files. `.env` is intentionally tracked (anon Supabase
# key only, RLS-protected). These mode-scoped variants are NOT tracked, so a
# developer who creates `.env.production` with a service-role key for local
# testing can't accidentally commit it. (`*.local` above already covers
# `.env.local` / `.env.*.local`.)
.env.development
.env.production
.env.staging
.env.test

